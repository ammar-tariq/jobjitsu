{
  "name": "@jobjitsu/app",
  "version": "0.0.0",
  "private": true,
  "description": "JobJitsu desktop shell (Tauri host + React webview)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "build": "tsc -b && vite build",
    "build:tauri": "tauri build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist dist-ui coverage .turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@jobjitsu/ai": "workspace:*",
    "@jobjitsu/core": "workspace:*",
    "@jobjitsu/events": "workspace:*",
    "@jobjitsu/identity": "workspace:*",
    "@jobjitsu/logger": "workspace:*",
    "@jobjitsu/preferences": "workspace:*",
    "@jobjitsu/send": "workspace:*",
    "@jobjitsu/shared": "workspace:*",
    "@jobjitsu/ui": "workspace:*",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  }
}
