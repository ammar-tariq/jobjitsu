{
  "name": "@jobjitsu/app",
  "version": "0.0.0",
  "private": true,
  "description": "JobJitsu desktop shell (Tauri host + React UI) \u2014 scaffold only",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist coverage .turbo ui/dist",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@jobjitsu/ui": "workspace:*",
    "@jobjitsu/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
