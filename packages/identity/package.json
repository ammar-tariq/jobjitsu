{
  "name": "@jobjitsu/identity",
  "version": "0.0.0",
  "private": true,
  "description": "Profile and r\u00e9sum\u00e9 source of truth (local)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage-resume-library.d.ts",
      "import": "./dist/storage-resume-library.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@jobjitsu/core": "workspace:*",
    "@jobjitsu/shared": "workspace:*",
    "@jobjitsu/storage": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist coverage .turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
