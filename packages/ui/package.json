{
  "name": "@jobjitsu/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Jj* UI primitives and design tokens",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./JjAgentPrivacyPill.css": "./src/JjAgentPrivacyPill.css"
  },
  "files": [
    "dist",
    "src/tokens.css",
    "src/JjAgentPrivacyPill.css"
  ],
  "dependencies": {
    "@jobjitsu/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist coverage .turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
